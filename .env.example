# Copy this file to .env and fill in your API keys
# cp .env.example .env

# CryptoCompare News API (무료 등록 후 발급, 월 100,000 calls)
# https://min-api.cryptocompare.com
CRYPTOCOMPARE_API_KEY=your_key_here

# CoinGecko News API — no key required for the free Demo tier (30 req/min)
# If you have a paid CoinGecko API key, set it here for higher rate limits:
# COINGECKO_API_KEY=your_key_here
